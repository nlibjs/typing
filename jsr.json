{
	"name": "@nlib/typing",
	"description": "A tool for generating and managing TypeScript type definitions efficiently.",
	"version": "3.0.4",
	"exports": {
		".": "./src/mod.ts",
		"./core": "./src/core.ts",
		"./is/Array": "./src/is/Array.ts",
		"./is/Base64String": "./src/is/Base64String.ts",
		"./is/Base64UrlString": "./src/is/Base64UrlString.ts",
		"./is/Boolean": "./src/is/Boolean.ts",
		"./is/DomainName": "./src/is/DomainName.ts",
		"./is/EmailAddress": "./src/is/EmailAddress.ts",
		"./is/EmailAddressLocalPart": "./src/is/EmailAddressLocalPart.ts",
		"./is/FiniteNumber": "./src/is/FiniteNumber.ts",
		"./is/Function": "./src/is/Function.ts",
		"./is/HttpMethod": "./src/is/HttpMethod.ts",
		"./is/HttpResponseStatusCode": "./src/is/HttpResponseStatusCode.ts",
		"./is/HttpsUrlString": "./src/is/HttpsUrlString.ts",
		"./is/Ipv4Address": "./src/is/Ipv4Address.ts",
		"./is/Ipv6Address": "./src/is/Ipv6Address.ts",
		"./is/NegativeFiniteNumber": "./src/is/NegativeFiniteNumber.ts",
		"./is/NegativeSafeInteger": "./src/is/NegativeSafeInteger.ts",
		"./is/Never": "./src/is/Never.ts",
		"./is/NonNegativeFiniteNumber": "./src/is/NonNegativeFiniteNumber.ts",
		"./is/NonNegativeSafeInteger": "./src/is/NonNegativeSafeInteger.ts",
		"./is/NonPositiveFiniteNumber": "./src/is/NonPositiveFiniteNumber.ts",
		"./is/NonPositiveSafeInteger": "./src/is/NonPositiveSafeInteger.ts",
		"./is/Null": "./src/is/Null.ts",
		"./is/Object": "./src/is/Object.ts",
		"./is/PositiveFiniteNumber": "./src/is/PositiveFiniteNumber.ts",
		"./is/PositiveSafeInteger": "./src/is/PositiveSafeInteger.ts",
		"./is/SafeInteger": "./src/is/SafeInteger.ts",
		"./is/String": "./src/is/String.ts",
		"./is/TypedArray": "./src/is/TypedArray.ts",
		"./is/UUID": "./src/is/UUID.ts",
		"./is/UUIDLowercase": "./src/is/UUIDLowercase.ts",
		"./is/UUIDUppercase": "./src/is/UUIDUppercase.ts",
		"./is/Undefined": "./src/is/Undefined.ts",
		"./is/UrlHostString": "./src/is/UrlHostString.ts",
		"./is/ValidDate": "./src/is/ValidDate.ts"
	},
	"publish": {
		"include": [
			"LICENSE.txt",
			"README.md",
			"src/**/*"
		],
		"exclude": [
			"**/*.test.ts"
		]
	}
}
